{
  "name": "@youde/portal",
  "version": "0.0.1",
  "license": "MIT",
  "author": "Javionlog",
  "type": "module",
  "scripts": {
    "start:dev": "react-router dev --mode dev",
    "start:prod": "react-router dev --mode prod",
    "build:dev": "react-router build --mode dev && tsdown",
    "build:prod": "react-router build --mode prod && tsdown",
    "preview:dev": "node --env-file .env.dev ./server.js",
    "preview:prod": "node --env-file .env.prod ./server.js",
    "api-gen": "openapi-ts",
    "check": "react-router typegen && tsc && oxlint --fix && oxfmt",
    "lint-staged": "lint-staged --relative"
  },
  "dependencies": {
    "@react-router/express": "^8.0.1",
    "@react-router/node": "^8.0.1",
    "@react-router/serve": "^8.0.1",
    "ahooks": "^3.8.5",
    "compression": "^1.8.1",
    "consola": "^3.4.2",
    "date-fns": "^4.1.0",
    "es-toolkit": "^1.39.10",
    "express": "^5.1.0",
    "http-proxy-middleware": "^3.0.5",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-fetch-backend": "^7.0.0",
    "isbot": "^5",
    "mitt": "^3.0.1",
    "morgan": "^1.10.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^16.0.0",
    "react-router": "^8.0.1",
    "remix-i18next": "^7.4.2",
    "tailwindcss": "^4.1.10",
    "tdesign-icons-react": "^0.5.1",
    "tdesign-mobile-react": "^0.20.0",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@hey-api/openapi-ts": "^0.84.2",
    "@react-router/dev": "^8.0.1",
    "@tailwindcss/vite": "^4.1.13",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.3",
    "@types/express-serve-static-core": "^5.1.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@youde/shared": "workspace:^",
    "babel-plugin-react-compiler": "^1.0.0",
    "mlly": "^1.8.0",
    "tsdown": "^0.22.1",
    "unplugin-auto-import": "^20.0.0",
    "vite-plugin-babel": "^1.3.2"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc,css,html}": [
      "tsc && oxlint --fix && oxfmt"
    ]
  },
  "engines": {
    "node": ">=22.22.3"
  },
  "packageManager": "pnpm@9.0.0"
}
