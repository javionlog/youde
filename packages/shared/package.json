{
  "name": "@youde/shared",
  "version": "0.0.1",
  "license": "MIT",
  "author": "Javionlog",
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/main.d.cts",
        "default": "./dist/main.cjs"
      },
      "import": {
        "types": "./dist/main.d.ts",
        "default": "./dist/main.js"
      }
    }
  },
  "scripts": {
    "build:dev": "tsdown",
    "build:prod": "tsdown",
    "check": "tsc && oxlint --fix && oxfmt",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "tsdown": "^0.22.1",
    "unrun": "^0.3.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc,css,html}": [
      "tsc && oxlint --fix && oxfmt"
    ]
  },
  "engines": {
    "node": ">=22.22.3"
  },
  "packageManager": "pnpm@9.0.0"
}
